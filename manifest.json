{
  "manifest_version": 3,
  "name": "Fokus",
  "version": "0.2.4",
  "description": "Block distracting parts of Instagram, YouTube and TikTok with per-site focus controls.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://instagram.com/*",
    "https://www.instagram.com/*",
    "https://m.instagram.com/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://tiktok.com/*",
    "https://www.tiktok.com/*",
    "https://m.tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://instagram.com/*",
        "https://www.instagram.com/*",
        "https://m.instagram.com/*",
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://music.youtube.com/*",
        "https://tiktok.com/*",
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Fokus",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
